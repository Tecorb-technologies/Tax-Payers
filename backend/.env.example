# Copy this file to .env and fill in real values. Never commit the actual .env file.

NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Database (unused in this MVP — in-memory data only)
DATABASE_URL=

# Auth (unused in this MVP — no authentication)
JWT_SECRET=
SESSION_SECRET=

# AI chat (bring-your-own-key: provider/model/key are supplied per request
# by the client and are never stored server-side). Optional override for
# where the backend looks for a local Ollama instance; defaults to
# http://localhost:11434 if unset.
OLLAMA_BASE_URL=
