# Copy this file to .env (backend) and .env.local or .env (frontend, Vite-prefixed vars only)
# and fill in real values. Never commit the actual .env file.

# --- Backend (Node/Express) ---
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=

# Auth
JWT_SECRET=
SESSION_SECRET=

# --- Frontend (React/Vite) ---
# Vite only exposes vars prefixed with VITE_ to client code.
VITE_API_URL=http://localhost:5000/api
